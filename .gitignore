# ── Secrets — NEVER COMMIT ───────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# ── Raw scraped data ─────────────────────────────────────────────────────────
# These directories are large, binary-adjacent, and fully regenerated each run.
data/raw/
data/staging/

# ── Generated artifacts — force-added at submission (Step 14) ────────────────
# Binary/large outputs that change every pipeline run. Excluded during the build
# to avoid noisy diffs and repo bloat. At submission, use `git add -f data/db/
# data/exports/` to include the final pipeline.db and exported spreadsheets.
data/db/
data/exports/

# ── Playwright ───────────────────────────────────────────────────────────────
.playwright/

# ── IDE and OS ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ── Test / type / lint caches ────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# ── Intentionally KEPT in git (flywheel state) ───────────────────────────────
